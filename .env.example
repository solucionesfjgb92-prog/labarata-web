# ══════════════════════════════════════════════
#  VARIABLES DE ENTORNO — Servidor La Barata
#  IMPORTANTE: NUNCA subas este archivo a GitHub
#  Renombra este archivo a ".env" antes de usar
# ══════════════════════════════════════════════

# ── TOKEN BSALE ────────────────────────────────
# Solicítalo a ayuda@bsale.app con tu RUT de empresa
# Ejemplo: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
BSALE_TOKEN=PEGA_AQUI_TU_TOKEN_DE_BSALE

# ── ID DE TU SUCURSAL (office) ─────────────────
# Encuéntralo en Bsale: Configuración > Sucursales
# O llamando a GET /api/sucursales con el servidor encendido
BSALE_OFFICE_ID=1

# ── ID LISTA DE PRECIOS ────────────────────────
# Encuéntralo en Bsale: Inventario > Listas de precios
# O llamando a GET /api/precios con el servidor encendido
BSALE_PRICE_LIST=1

# ── TIPO DE DOCUMENTO ─────────────────────────
# 8 = Nota de Venta (pre-venta, no emite al SII)
# Consulta tus tipos en Bsale: Configuración > Tipos de documentos
BSALE_DOCUMENT_TYPE=8

# ── URL DE TU PÁGINA WEB ──────────────────────
# Permite que solo tu web pueda llamar al servidor
# En desarrollo usa * (permite todos)
# En producción pon tu dominio: https://labarata.cl
FRONTEND_URL=*

# ── PUERTO DEL SERVIDOR ────────────────────────
# Render lo asigna automáticamente; en local usa 3000
PORT=3000
